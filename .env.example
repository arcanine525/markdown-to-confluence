# Confluence Cloud credentials
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USER=you@example.com
CONFLUENCE_TOKEN=your_api_token_here
CONFLUENCE_SPACE=SPACEKEY

# Optional: parent page ID (find it in the URL when viewing a page)
CONFLUENCE_PARENT_ID=
